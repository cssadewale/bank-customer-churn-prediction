# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Bank Customer Churn Prediction
# ──────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Jupyter Notebook Checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Environment Variables & Secrets ──────────────────────────────────────────
.env
.env.local
*.secret

# ── OS Generated Files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDEs & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# ── Data Files (large — use Git LFS or cloud storage instead) ─────────────────
# Uncomment the line below if your dataset is too large for GitHub (>100MB)
# data/*.csv

# ── Temporary & Log Files ─────────────────────────────────────────────────────
*.log
*.tmp
*.temp
tmp/
temp/

# ── Coverage & Testing ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/
